# Environment Variables for Railway Deployment
# Copy this file and set these values in Railway dashboard

# ============================================
# MYSQL (Railway MySQL Database)
# ============================================
# Get these values from your Railway MySQL service
DB_HOST=containers-us-west-123.railway.app
DB_PORT=6543
DB_USER=root
DB_PASS=your-railway-mysql-password-here
DB_NAME=railway

# ============================================
# MONGODB (MongoDB Atlas)
# ============================================
# Get this from MongoDB Atlas: Clusters → Connect → Connect your application
MONGO_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=user_profiles_db

# ============================================
# REDIS (Redis Cloud)
# ============================================
# Get these from Redis Cloud dashboard
REDIS_HOST=redis-12345.c123.us-east-1-1.ec2.cloud.redislabs.com
REDIS_PORT=12345
REDIS_PASSWORD=your-redis-cloud-password-here

# ============================================
# SESSION CONFIGURATION
# ============================================
SESSION_TIMEOUT=3600

# ============================================
# NOTES:
# ============================================
# 1. Never commit this file with real credentials to GitHub
# 2. In Railway, set these in: Service → Variables tab
# 3. Railway will automatically inject these as environment variables
# 4. The config.php file uses getenv() to read these values
# 5. For MongoDB Atlas:
#    - Replace 'username' with your Atlas username
#    - Replace 'password' with your Atlas password
#    - Replace 'cluster.xxxxx' with your actual cluster URL
# 6. Keep the .env file in .gitignore
